{
  "name": "talks",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && pnpm -r run build",
    "build:gh-pages": "pnpm clean && pnpm --filter \"./2026-*/src\" run build:gh-pages",
    "dev": "tsx scripts/picker.ts dev --open",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "export": "tsx scripts/picker.ts export",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@iconify/json": "catalog:",
    "@slidev/cli": "catalog:",
    "@slidev/client": "catalog:",
    "@slidev/theme-default": "catalog:",
    "@slidev/theme-seriph": "catalog:",
    "seedrandom": "catalog:",
    "markdown-it-magic-link": "catalog:",
    "tailwind-merge": "catalog:",
    "unocss": "catalog:"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@types/prompts": "catalog:",
    "@types/seedrandom": "catalog:",
    "eslint": "catalog:",
    "execa": "catalog:",
    "playwright-chromium": "catalog:",
    "prompts": "catalog:",
    "rimraf": "catalog:",
    "serve": "catalog:",
    "typescript": "catalog:"
  }
}
